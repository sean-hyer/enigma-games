        //const puzzle = ["cwsqoyouilvkoxnafrbetdnzhmgupe", "BDENTFHIRGEA", ["stadium", "comment", "silver", "sumo", "quad", "over", "oven"]];
        //const puzzle = ["sctfxwrdgzpoljubdeyqihntkvnoam", "OUBXEKJUEHRG", ["foundry", "crooked", "woken", "word", "crop"]];
        //const puzzle = ["vinbcwetchtmigstrdolrouarhoiyf", "SNOYVUENRIUG", ["velocity", "warmth", "chord", "birth", "itch"]];
        //const puzzle = ["gsibyckghoxeiaowmeoultfvrntrpd", "STPOAMCOHTEL", ["ignored", "brought", "boxer", "grin", "goat"]];
        //const puzzle = ["gmhszfcenvxpseobdetkjulliyaqfw", "AOCLIHTPDYRU", ["subject", "myself", "flick", "menu", "flip"]];
        //const puzzle = ["sowlycazintulygupdhkqbrervfmoa", "ELROUWSBAWBY", ["winter", "lizard", "liquor", "curly"]];
        //const puzzle = ["vwnsbkrcartzdflegumoihejsxytop", "TIUKENPAOREB", ["shortly", "sailor", "shelf", "bogus", "bray", "beet"]];
        //const puzzle = ["zbohkcdmrlyhgtlupraivoeansdafw", "IUEDSNFOTIAC", ["hopeful", "careful", "chasm", "oval", "omit", "halt"]];
        //const puzzle = ["bldmwfuitesqhlnpcaerysrloasodg", "PALOAETHENMR", ["mesquite", "monster", "boards", "liter", "flour", "burst"]];
        //const puzzle = ["kmbrwcedoeloundrucgyshpinfiabt", "EADFINCYUTRL", ["republic", "concur", "rodeo", "bingo", "menu", "knit"]];
        //const puzzle = ["gvdtaexwijolhlepiuofmesqzybknc", "CVELOUMDNIAO", ["timely", "tennis", "gloss", "equip", "golf"]];
        //const puzzle = ["dfjptikuribeigkyxknlenacohntos", "ULAENGISHTGY", ["jukebox", "pretty", "funky", "fungi", "tiny", "icon", "deck"]];
        const puzzle = ["umptgrlyewnetoibdfvtoyocsarvch", "OASCENPXERRF", ["poverty", "tycoon", "proven", "myrtle", "maven", "match", "rely"]];

        const linkLetters = puzzle[0], nodes = puzzle[1], lWords = puzzle[2];

        const links = linkLocs.map((loc, i) => [loc[0], loc[1], linkLetters[i]]);
        let nWords = Array(lWords.length).fill(false);
        let linkDisabled = Array(links.length).fill(false);
        let done = false;

        // identify links which are used in the solutions, by walking through lWords
        let linkNeeded = Array(links.length).fill(false);
        for (let w of lWords) {
            let loc = -1;
            for (let l of w) {
                for (let iLink = 0; iLink < links.length; ++iLink) {
                    if (links[iLink][2] != l)
                        continue;
                    if (links[iLink][0] == loc || links[iLink][1] == loc) {
                        linkNeeded[iLink] = true;
                        loc = links[iLink][0] + links[iLink][1] - loc;
                        break;
                    }
                }
            }
        }

        let twinklers = [];
        function drawTwinklers(ctx, timeMs) {
            const t = timeMs * 0.005; // speed control
            const phase = Math.random() * Math.PI * 2;
            for (let i = 0; i < twinklers.length; ++i) {
                const [x, y] = twinklers[i];
                const alpha = 0.25 + 0.75 * (0.5 + 0.5 * Math.sin(t + phase)); // 0.25..1.0 flashing
                ctx.save();
                ctx.lineWidth = 2; // 2-pixel-wide stroke
                ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;
                const r = 2; // diamond half‑size
                ctx.beginPath();
                ctx.moveTo(x, y - r);
                ctx.lineTo(x + r, y);
                ctx.lineTo(x, y + r);
                ctx.lineTo(x - r, y);
                ctx.closePath();
                ctx.stroke();
                ctx.restore();
            }
        }
        // create an overlay canvas that sits on top of the main canvas
        const overlay = document.createElement('canvas');
        overlay.id = 'twinkleOverlay';
        overlay.style.position = 'absolute';
        overlay.style.left = '0';
        overlay.style.top = '0';
        overlay.style.width = '100vw';
        overlay.style.height = '100vh';
        overlay.style.pointerEvents = 'none';
        overlay.style.zIndex = '999';
        overlay.width = canvas.width;
        overlay.height = canvas.height;
        document.body.appendChild(overlay);
        const octx = overlay.getContext('2d');

        // keep overlay sized to the logical canvas dimensions when window changes
        function resizeOverlay() {
            // keep logical size in sync with main canvas
            overlay.width = canvas.width;
            overlay.height = canvas.height;
            // match CSS size so drawing aligns with mouse coordinates
            overlay.style.width = canvas.style.width || `${window.innerWidth}px`;
            overlay.style.height = canvas.style.height || `${window.innerHeight}px`;
        }
        window.addEventListener('resize', resizeOverlay);

        // layout and graphing
        let halfStep = Math.PI / halfSize;
        const xCenter = 260, yCenter = 270;  // xCenter should be half the logical canvas width, hardcoded above
        const rOuter = 200, rInner = 125, rNode = 22, rStart = 27, rStar = 21;
        const rLWord = 290, thetaLWord = -0.1 * Math.PI;
        const rNWord = rLWord + 35, thetaNWord = thetaLWord * rLWord / rNWord;
        const rWord = 280, vWord = 40, rHint = 370;
        const thetaWord = 0.06 * Math.PI, thetaHint = -0.29;
        const hText = 0, vText = 7, hHint = 96, vHint = 30;
        const rInbound = 166, rOutbound = rInbound;
        const thetaOffset = 6.28 * Math.random();

        function circleAt(canvasContext, x, y, r = rNode, bright = false) {
            canvasContext.lineWidth = 1;
            canvasContext.beginPath();
            canvasContext.arc(x, y, r, 0, 2 * Math.PI);
            canvasContext.stroke();
            canvasContext.fillStyle = bright ? "#FFFFFF" : "#FFEEDD";
            canvasContext.fill();
        }

        function xCoord(r, theta, xMid = xCenter) {
            return xMid + r * Math.sin(theta);
        }
        function yCoord(r, theta, yMid = yCenter) {
            return yMid + r * Math.cos(theta);
        }

        twinklers = [[xCenter, yCenter]];
        function twinklerAt(r, theta) {
            twinklers.push([xCoord(r, theta), yCoord(r, theta)]);
        }
        // animation loop — runs even with no user events
        function animateTwinkles(timeMs) {
            // clear only overlay so the main canvas is left intact
            octx.clearRect(0, 0, overlay.width, overlay.height);
            drawTwinklers(octx, timeMs);
            requestAnimationFrame(animateTwinkles);
        }
        // start the loop
        requestAnimationFrame(animateTwinkles);

        linkCenters = Array(links.length).fill([0, 0]);
        for (let i = 0; i < halfSize; i++) {
            let theta = 2 * i * halfStep + thetaOffset;
            let thetaOuter = theta + halfStep;

            linkCenters[startLinks[i]] = [(rStart + rInner) / 2, theta + 0.75 * halfStep];
            linkCenters[outerLinks[i]] = [rOuter - 0.1 * rNode, theta];
            linkCenters[innerLinks[i]] = [rInner - 0.1 * rNode, theta + halfStep];
            linkCenters[inboundLinks[i]] = [(rInner + rOuter) / 2, (theta + thetaOuter) / 2 - 0.125 * halfStep];
            linkCenters[outboundLinks[i]] = [(rInner + rOuter) / 2, theta - 0.375 * halfStep];
       }

        nodeCenters = Array(nNodes).fill([0, 0]);
        for (let i = 0; i < halfSize; i++) {
            let theta = 2 * i * halfStep + thetaOffset;
            let thetaOuter = theta - halfStep;
            nodeCenters[i * 2] = [rInner, theta];
            nodeCenters[i * 2 + 1] = [rOuter, thetaOuter];
            //twinklerAt(...nodeCenters[i * 2]);
        }
      

        const xHintLo = xCoord(rHint, thetaHint) - hHint / 2, xHintHi = xHintLo + hHint;
        const yHintLo = yCoord(rHint, thetaHint), yHintHi = yHintLo + vHint;

        function textAt(text, r, theta, hollow = true) {
            if (hollow) {
                ctx.lineWidth = 1;
                ctx.font = text == "i" ? "20px Baron" : "22px Consolas";
                ctx.strokeText(text, xCoord(r, theta) - hText, yCoord(r, theta) + vText);
            }
            else {
                ctx.fillStyle = "black";
                ctx.lineWidth = 2;
                ctx.font = text == "I" ? "20px Baron" : "22px Consolas";
                ctx.fillText(text, xCoord(r, theta) - hText, yCoord(r, theta) + vText);
            }
        }

        function drawGraph(canvasContext, loc, linkV, nodeV, rScale = 1.0, thetaShift = 0.0, xMid = xCenter, yMid = yCenter) 
        {
            for (let i = 0; i < halfSize; i++) {
                let theta = 2 * i * halfStep + thetaOffset + thetaShift;
                let thetaOuter = theta + halfStep;
                canvasContext.font = "24px Consolas";

                // start link
                let iLink = startLinks[i];
                if (rScale == 1.0 && !linkDisabled[iLink]) {
                    let thetaAim = theta + (loc < 0 ? 1.25 : 1.5) * halfStep;
                    let rAim = rInner * 0.8 * rScale;
                    canvasContext.lineWidth = linkV[iLink] ? 4 : 2;
                    canvasContext.beginPath();
                    canvasContext.moveTo(xCoord(rStart, theta, xMid), yCoord(rStart, theta, yMid));
                    canvasContext.quadraticCurveTo(xCoord(rAim, thetaAim, xMid), yCoord(rAim, thetaAim, yMid), xCoord(rInner, theta, xMid), yCoord(rInner, theta, yMid));
                    canvasContext.stroke();
                    if (rScale == 1.0 && loc < 0) {
                        textAt(links[iLink][2], 0.375 * rInner, theta + 0.2 * halfStep);
                    }
                }

                // outer-edge link
                iLink = outerLinks[i];
                if (!linkDisabled[iLink]) {
                    rAim = (rOuter + 0.7 * rNode) * rScale;
                    thetaAim = thetaOuter - halfStep;
                    let rEnd = (rOuter + 0.6 * rNode) * rScale;
                    canvasContext.lineWidth = linkV[iLink] ? 4 : 2;
                    canvasContext.beginPath();
                    canvasContext.moveTo(xCoord(rEnd, thetaOuter, xMid), yCoord(rEnd, thetaOuter, yMid));
                    canvasContext.quadraticCurveTo(xCoord(rAim, thetaAim, xMid), yCoord(rAim, thetaAim, yMid), xCoord(rEnd, thetaOuter - 2 * halfStep, xMid), yCoord(rEnd, thetaOuter - 2 * halfStep, yMid));
                    canvasContext.stroke();
                    if (rScale == 1.0) { textAt(links[iLink][2], rAim, thetaAim); }
                }

                // inner-edge link
                iLink = innerLinks[i];
                if (!linkDisabled[iLink]) {
                    rAim = (rInner + 0.3 * rNode) * rScale;
                    thetaAim = theta + halfStep;
                    rEnd = (rInner + 0.1 * rNode) * rScale;
                    canvasContext.lineWidth = linkV[iLink] ? 4 : 2;
                    canvasContext.beginPath();
                    canvasContext.moveTo(xCoord(rEnd, theta, xMid), yCoord(rEnd, theta, yMid));
                    canvasContext.quadraticCurveTo(xCoord(rAim, thetaAim, xMid), yCoord(rAim, thetaAim, yMid), xCoord(rEnd, theta + 2 * halfStep, xMid), yCoord(rEnd, theta + 2 * halfStep, yMid));
                    canvasContext.stroke();
                    if (rScale == 1.0) { textAt(links[iLink][2], (rInner - 0.6 * rNode) * rScale, thetaAim); }
                }

                // outer-to-inner (conventionally anyway)
                iLink = inboundLinks[i];
                if (!linkDisabled[iLink]) {
                    thetaAim = theta + 0.4 * halfStep;
                    canvasContext.lineWidth = linkV[iLink] ? 4 : 2;
                    canvasContext.beginPath();
                    canvasContext.moveTo(xCoord(rInner * rScale, theta, xMid), yCoord(rInner * rScale, theta, yMid));
                    canvasContext.quadraticCurveTo(xCoord(rOuter * rScale, thetaAim, xMid), yCoord(rOuter * rScale, thetaAim, yMid), xCoord(rOuter * rScale, thetaOuter, xMid), yCoord(rOuter * rScale, thetaOuter, yMid));
                    canvasContext.stroke();
                    if (rScale == 1.0) { textAt(links[iLink][2], rInbound * rScale, thetaAim + 0.14 * halfStep); }
                }

                // inner-to-outer
                iLink = outboundLinks[i];
                if (!linkDisabled[iLink]) {
                    thetaAim = theta - 0.4 * halfStep;
                    canvasContext.lineWidth = linkV[iLink] ? 4 : 2;
                    canvasContext.beginPath();
                    canvasContext.moveTo(xCoord(rInner * rScale, theta, xMid), yCoord(rInner * rScale, theta, yMid));
                    canvasContext.quadraticCurveTo(xCoord(rOuter * rScale, thetaAim, xMid), yCoord(rOuter * rScale, thetaAim, yMid), xCoord(rOuter * rScale, theta - halfStep, xMid), yCoord(rOuter * rScale, theta - halfStep, yMid));
                    canvasContext.stroke();
                    if (rScale == 1.0) { textAt(links[iLink][2], rInbound * rScale, thetaAim - 0.14 * halfStep); }
                }
            }

            // draw nodes in foreground (i.e., after links)
            for (let i = 0; i < halfSize; i++) {
                let theta = 2 * i * halfStep + thetaOffset + thetaShift;
                let thetaOuter = theta - halfStep;

                circleAt(canvasContext, xCoord(rInner * rScale, theta, xMid), yCoord(rInner * rScale, theta, yMid), rNode * rScale, loc == 2 * i);
                circleAt(canvasContext, xCoord(rOuter * rScale, thetaOuter, xMid), yCoord(rOuter * rScale, thetaOuter, yMid), rNode * rScale, loc == 2 * i + 1);
                if (rScale == 1.0) {
                    ctx.font = (nodeV[2 * i] ? "bold" : "italic") + " 18px Arial";
                    textAt(nodes[i * 2], rInner, theta, false);
                    ctx.font = (nodeV[2 * i + 1] ? "bold" : "italic") + " 18px Arial";
                    textAt(nodes[i * 2 + 1], rOuter, thetaOuter, false);
                }
            }
        }

        function traceLinks(path)
        {
            let lWord = "", nWord = "";
            let linkV = Array(nLinks).fill(false), nodeV = Array(nNodes).fill(false);
            let loc = -1;
            for (let ic = 0; ic < path.length; ++ic) {
                let newLoc = -1, iLink = -1;
                while (newLoc < 0 && ++iLink < nLinks) {
                    if (links[iLink][2] == path[ic]) {
                        if (links[iLink][0] == loc) { newLoc = links[iLink][1]; }
                        else if (links[iLink][1] == loc) { newLoc = links[iLink][0]; }
                    }
                }
                if (newLoc >= 0) {
                    linkV[iLink] = true;
                    nodeV[newLoc] = true;
                    lWord += path[ic];
                    nWord += nodes[newLoc];
                    loc = newLoc;
                }
            }
            return [loc, lWord, nWord, linkV, nodeV];
        }

        function drawGame(path) {
            // compute and display progress
            const lPow = 1.62;
            let nFound = 0, nTotal = 0;
            for (let iw = 0; iw < lWords.length; ++iw) {
                nTotal += Math.pow(lWords[iw].length, lPow);
                if (nWords[iw]) { nFound += Math.pow(lWords[iw].length, lPow); }
            }

            const [loc, lWord, nWord, linkV, nodeV] = traceLinks(path);

            ctx.clearRect(0, 0, canvas.width, canvas.height);
            if (nFound) {
                if (nFound == nTotal) {
                    document.body.style.backgroundColor = colorWin;
                }
                else {
                    const ePow = 1.41;
                    const frac = nFound / nTotal;
                    const nMin = Math.round(ctx.canvas.height * Math.pow(frac, ePow));
                    const nMax = frac == 1 ? ctx.canvas.height : Math.round(ctx.canvas.height * (1.0 - Math.pow(1.0 - frac, ePow)));
                    const gradient = ctx.createLinearGradient(0, ctx.canvas.height - nMax, 0, ctx.canvas.height - nMin);
                    gradient.addColorStop(0, colorHi);
                    gradient.addColorStop(1, colorLo);
                    ctx.fillStyle = gradient;
                    ctx.fillRect(0, ctx.canvas.height - nMax, ctx.canvas.width, nMax);
                }
            }
            drawGraph(ctx, loc, linkV, nodeV);

            // draw the starting region
            ctx.beginPath();
            for (let i = 0; i <= halfSize; i++) {
                let theta = 2 * i * halfStep + thetaOffset;
                if (i == 0)
                    ctx.moveTo(xCoord(rStart, theta), yCoord(rStart, theta));
                else
                    ctx.lineTo(xCoord(rStart, theta), yCoord(rStart, theta));
            }
            ctx.stroke();
            ctx.fillStyle = "black";
            ctx.fill();
            if (loc < 0) {
                ctx.strokeStyle = "white";
                for (let i = 0; i < halfSize; i++) {
                    let theta = 2 * i * halfStep + thetaOffset;
                    ctx.beginPath();
                    ctx.moveTo(xCoord(0, theta), yCoord(0, theta));
                    ctx.lineTo(xCoord(rStar, theta), yCoord(rStar, theta));
                    ctx.stroke();
                }
                ctx.strokeStyle = "black";
            }

            // show the target words
            for (let iw = 0; iw < lWords.length; ++iw) {
                const wordLeft = xCoord(rWord, thetaWord);
                const wordTop = yCoord(rWord, thetaWord) - lWords.length * vText + iw * vWord;
                if (nWords[iw]) {
                    ctx.textAlign = "left";
                    ctx.font = "20px Consolas";
                    ctx.lineWidth = 1;
                    ctx.strokeText(lWords[iw], wordLeft, wordTop + 3);
                    ctx.strokeText(nWords[iw], wordLeft + hText + 4, wordTop + 3 * vText);
                    ctx.textAlign = "center";
                }
                else {
                    let hStep = 16, rLetter = 8;
                    for (let il = 0; il < lWords[iw].length; ++il) {
                        let left = wordLeft + il * hStep;
                        ctx.beginPath();
                        if (il) {
                            ctx.moveTo(left - 3, wordTop + 3);
                            ctx.quadraticCurveTo(left - 2, wordTop - 9, left + rNode / 2, wordTop + 2);
                        }
                        else {
                            ctx.moveTo(left - 3, wordTop - 3);
                            ctx.lineTo(left + rNode / 4, wordTop + 3);
                        }
                        ctx.stroke();
                        circleAt(ctx, left + rNode / 2, wordTop + rNode / 2, rLetter + 1, false);
                        if (il == lWords[iw].length - 1) {
                            ctx.fillStyle = "black";
                            ctx.font = "12px Consolas";
                            ctx.fillText(il + 1, left + rNode / 2, wordTop + rNode / 2 + 5);
                        }
                    }
                }
            }
            // hint box
            ctx.beginPath();
            ctx.moveTo(xHintLo, yHintLo);
            ctx.lineTo(xHintLo, yHintHi);
            ctx.lineTo(xHintHi, yHintHi);
            ctx.lineTo(xHintHi, yHintLo);
            ctx.lineTo(xHintLo, yHintLo);
            ctx.fillStyle = done ? "#FFFFFF" : "#AACCAA";
            ctx.stroke();
            ctx.fill();
            ctx.textAlign = "left";
            ctx.font = "20px Georgia";
            ctx.strokeText(done ? "   Gloat" : "Too Hard!", xHintLo + 2, yHintHi - vText);
            ctx.textAlign = "center";

            // current state of play
            ctx.font = "24px Verdana";
            textAt(lWord, rLWord, thetaLWord);
            textAt(nWord, rNWord, thetaNWord, false);

            return [loc, lWord, nWord];
        }

        var state = drawGame("");

        function onEnter(path) {
            const where = lWords.indexOf(path);
            if (where >= 0) {
                nWords[where] = state[2];
                done = nWords.indexOf(false) < 0;
                if (done) {
                    for (let i = 0; i < links.length; ++i) { 
                        if (linkNeeded[i]) { twinklerAt(...linkCenters[i]); } 
                    }
                }
            } else {
                const al = document.getElementById('alrt');
                if (al) {
                    al.innerHTML = 'Not in word list';
                    setTimeout(function () { al.innerHTML = ''; }, 2500);
                }
            }
            // Enter clears the typed path
            return "";
        }

        document.addEventListener('keydown', (event) => {
            let path = state[1];
            if (event.keyCode == 8) { path = path.slice(0, -1); }
            else if (event.keyCode == 13) { path = onEnter(path); }
            else { path += event.key.toLowerCase(); }

            state = drawGame(path);
        });

        function toClipboard2(canvas) {
            canvas.convertToBlob().then(blob => {
                const item = new ClipboardItem({ 'image/png': blob });
                navigator.clipboard.write([item]).then(() => {
                    console.log('Image copied to clipboard!');
                }).catch(err => {
                    console.error('Error copying image to clipboard:', err);
                });
            });
        }

        function toLogicalPoint(event) {
            // bounding rect is in CSS pixels; canvas.width/height are the logical drawing units
            const rect = canvas.getBoundingClientRect();
            const scaleX = canvas.width / rect.width;
            const scaleY = canvas.height / rect.height;
            const x = (event.clientX - rect.left) * scaleX;
            const y = (event.clientY - rect.top) * scaleY;
            return { x, y };
        }

        document.addEventListener('click', (event) => {
            const p = toLogicalPoint(event);
            const mouseX = p.x, mouseY = p.y;
            function inCircle(r, theta) {
            let dx = mouseX - xCoord(r, theta);
            let dy = mouseY - yCoord(r, theta);
            return dx * dx + dy * dy < rNode * rNode;
        }

        let targetNode = -1;
        for (let i = 0; i < halfSize && targetNode < 0; i++) {
            let theta = 2 * i * halfStep + thetaOffset;
            let thetaOuter = theta - halfStep;

            if (inCircle(rInner, theta)) { targetNode = 2 * i; }
            if (inCircle(rOuter, thetaOuter)) { targetNode = 2 * i + 1; }
        }

        if (targetNode >= 0) {
            let loc = state[0];
            for (let iLink = 0; iLink < nLinks; ++iLink) {
                if ((links[iLink][0] == loc && links[iLink][1] == targetNode)
                || (links[iLink][1] == loc && links[iLink][0] == targetNode)) {
                    state = drawGame(state[1] + links[iLink][2]);
                    break;
                }
            }
        }

        if (inCircle(0, 0)) { state = drawGame(onEnter(state[1])); }

        if (mouseX > xHintLo && mouseX < xHintHi && mouseY > yHintLo && mouseY < yHintHi) {
            if (done) {
                // share
                const shareSize = 200;
                const tempCanvas = new OffscreenCanvas(shareSize, shareSize);  // Match the dimensions of the main canvas
                const tempCtx = tempCanvas.getContext('2d');

                let nHints = linkDisabled.filter(Boolean).length;
                let green = (3071 - 140 * nHints) / (12 + nHints);
                let red = 135 - green / 4;
                tempCtx.fillStyle = `rgb(${red}, ${green}, ${green})`;
                tempCtx.fillRect(0, 0, shareSize, shareSize);

                // Perform drawing operations on the temporary context
                let thetaShift = Math.random() * 2 * Math.PI;
                drawGraph(tempCtx, -1, linkNeeded, Array(nNodes).fill(true), 0.4, thetaShift, shareSize / 2, shareSize / 2);
                toClipboard2(tempCanvas);
            }
            else {
                removable = [];
                for (let ii = 0; ii < nLinks; ++ii) {
                    if (!linkDisabled[ii] && !linkNeeded[ii]) { removable.push(ii); }
                }
                if (removable.length) {
                    let remove = removable[Math.floor(Math.random() * removable.length)];
                    linkDisabled[remove] = true;
                    state = drawGame(state[1]);
                }
            }
        }
        });

    </script>
