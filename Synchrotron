        //const puzzle = ["lfdatoerlymcnmgtslpvewbihaikuy", "EOSTURCIKDRA", ["oceanic", "oyster", "family", "alive", "oily", "oils"]];
        //const puzzle = ["zshfciiniyxupwbretqlkgjnadevom", "NHAYTRSIOMCE", ["interview", "helium", "field", "held", "find", "cork"]];
        //const puzzle = ["pshadmykoivoilnjcutertoqbxigfw", "NIAGRMEYSVEL", ["attorney", "mobile", "doubt", "ditto", "skin"]];
        //const puzzle = ["acumpnkmdojxfertwvhzysbigtaelo", "PUILCAETRSDI", ["nightmare", "nobody", "posse", "moody", "ahead", "post"]];
